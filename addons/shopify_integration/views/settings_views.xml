<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_shopify" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.shopify</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Shopify" string="Shopify" name="shopify_integration" data-key="shopify_integration">
                    <block title="Depo Ayarları" name="shopify_warehouse">
                        <setting string="Sipariş Deposu" help="Shopify siparişlerinin düşeceği depo">
                            <div class="row mt16">
                                <label for="shopify_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="shopify_warehouse_id" class="col-4"/>
                            </div>
                        </setting>
                    </block>

                    <block title="Toplu Senkronizasyon" name="shopify_sync">
                        <setting string="Tüm Mağazalar" help="Tüm aktif mağazalardan siparişleri senkronize et">
                            <div class="mt8">
                                <button name="action_shopify_sync_all" icon="fa-refresh" type="object" string="Tüm Mağazaları Senkronize Et" class="btn-primary"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
