<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_picking_schedule" model="ir.cron">
            <field name="name">Toplama Listesi Zamanlayici</field>
            <field name="model_id" ref="model_ugurlar_picking_schedule"/>
            <field name="state">code</field>
            <field name="code">model._cron_run()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
        <!-- _gc_old_operations artık @api.autovacuum ile otomatik çalışır,
             ayrı cron kaydına gerek yoktur. -->
    </data>
</odoo>
