<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ai_studio_prompt_list" model="ir.ui.view">
        <field name="name">ai.studio.prompt.template.list</field>
        <field name="model">ai.studio.prompt.template</field>
        <field name="arch" type="xml">
            <list string="Prompt Şablonları" editable="bottom">
                <field name="name"/>
                <field name="scope"/>
                <field name="category_id" optional="show"/>
                <field name="prompt_text"/>
                <field name="usage_count"/>
                <field name="success_rate" widget="progressbar"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_studio_prompt_form" model="ir.ui.view">
        <field name="name">ai.studio.prompt.template.form</field>
        <field name="model">ai.studio.prompt.template</field>
        <field name="arch" type="xml">
            <form string="Prompt Şablonu">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="scope"/>
                            <field name="category_id" invisible="scope != 'category'"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="usage_count"/>
                            <field name="success_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <group string="Prompt Metni">
                        <field name="prompt_text" nolabel="1"
                               placeholder="AI'ya gönderilecek prompt metnini buraya yazın..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_studio_prompt" model="ir.actions.act_window">
        <field name="name">Prompt Şablonları</field>
        <field name="res_model">ai.studio.prompt.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
