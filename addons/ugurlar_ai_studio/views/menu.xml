<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ======================================================= -->
    <!-- Action tanimlari — view dosyalarindaki action'lari       -->
    <!-- tekrar tanimlayarak DB senkronizasyonunu garanti ederiz  -->
    <!-- ======================================================= -->

    <!-- Preset Action -->
    <record id="action_ai_studio_preset" model="ir.actions.act_window">
        <field name="name">Manken Presetleri</field>
        <field name="res_model">ai.studio.model.preset</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                İlk manken presetinizi oluşturun!
            </p>
        </field>
    </record>

    <!-- Prompt Action -->
    <record id="action_ai_studio_prompt" model="ir.actions.act_window">
        <field name="name">Prompt Şablonları</field>
        <field name="res_model">ai.studio.prompt.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Prompt şablonu ekleyin
            </p>
        </field>
    </record>

    <!-- Reject Reason Action -->
    <record id="action_ai_studio_reject" model="ir.actions.act_window">
        <field name="name">Red Sebepleri</field>
        <field name="res_model">ai.studio.reject.reason</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Session Action -->
    <record id="action_ai_studio_session" model="ir.actions.act_window">
        <field name="name">Oturumlar</field>
        <field name="res_model">ai.studio.session</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henüz çekim oturumu yok
            </p>
        </field>
    </record>

    <!-- Generation Action -->
    <record id="action_ai_studio_generation" model="ir.actions.act_window">
        <field name="name">AI Üretimler</field>
        <field name="res_model">ai.studio.generation</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Henüz AI üretimi yok
            </p>
        </field>
    </record>

    <!-- Settings Action -->
    <record id="action_ai_studio_config" model="ir.actions.act_window">
        <field name="name">AI Studio Ayarları</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'ugurlar_ai_studio'}</field>
    </record>

    <!-- Client Action — OWL uygulamasi giris noktasi -->
    <record id="ai_studio_client_action" model="ir.actions.client">
        <field name="name">AI Stüdyo</field>
        <field name="tag">ugurlar_ai_studio.main</field>
    </record>

    <!-- ======================================================= -->
    <!-- Root Menu — Navbar'da AI Studio uygulamasi               -->
    <!-- ======================================================= -->
    <menuitem id="menu_ai_studio_root"
              name="AI Stüdyo"
              web_icon="ugurlar_ai_studio,static/description/icon.png"
              sequence="45"/>

    <!-- ======================================================= -->
    <!-- 1. Seviye: Ana Navbar Menuleri                           -->
    <!-- ======================================================= -->

    <!-- AI Studyo — Mobil uygulama (client action) -->
    <menuitem id="menu_ai_studio_app"
              name="AI Stüdyo"
              parent="menu_ai_studio_root"
              action="ai_studio_client_action"
              sequence="1"/>

    <!-- Oturumlar — Tum cekim oturumlari listesi -->
    <menuitem id="menu_ai_studio_sessions"
              name="Oturumlar"
              parent="menu_ai_studio_root"
              action="action_ai_studio_session"
              sequence="10"/>

    <!-- AI Uretimler — Tum AI gorsel uretimler -->
    <menuitem id="menu_ai_studio_generations"
              name="AI Üretimler"
              parent="menu_ai_studio_root"
              action="action_ai_studio_generation"
              sequence="20"/>

    <!-- ======================================================= -->
    <!-- 2. Seviye: Yapilandirma Alt Menusu                      -->
    <!-- ======================================================= -->

    <menuitem id="menu_ai_studio_config"
              name="Yapılandırma"
              parent="menu_ai_studio_root"
              sequence="90"/>

    <!-- Manken Presetleri -->
    <menuitem id="menu_ai_studio_presets"
              name="Manken Presetleri"
              parent="menu_ai_studio_config"
              action="action_ai_studio_preset"
              sequence="1"/>

    <!-- Prompt Sablonlari -->
    <menuitem id="menu_ai_studio_prompts"
              name="Prompt Şablonları"
              parent="menu_ai_studio_config"
              action="action_ai_studio_prompt"
              sequence="2"/>

    <!-- Red Sebepleri -->
    <menuitem id="menu_ai_studio_reject_reasons"
              name="Red Sebepleri"
              parent="menu_ai_studio_config"
              action="action_ai_studio_reject"
              sequence="3"/>

    <!-- Genel Ayarlar — res.config.settings sayfasi -->
    <menuitem id="menu_ai_studio_settings"
              name="Genel Ayarlar"
              parent="menu_ai_studio_config"
              action="action_ai_studio_config"
              sequence="99"/>
</odoo>
