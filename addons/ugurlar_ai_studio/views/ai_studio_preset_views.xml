<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="view_ai_studio_preset_list" model="ir.ui.view">
        <field name="name">ai.studio.model.preset.list</field>
        <field name="model">ai.studio.model.preset</field>
        <field name="arch" type="xml">
            <list string="Manken Presetleri">
                <field name="name"/>
                <field name="gender"/>
                <field name="body_type"/>
                <field name="garment_type"/>
                <field name="background_type"/>
                <field name="mannequin_generation_state" widget="badge"
                       decoration-info="mannequin_generation_state == 'generating'"
                       decoration-success="mannequin_generation_state == 'done'"
                       decoration-danger="mannequin_generation_state == 'failed'"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ai_studio_preset_form" model="ir.ui.view">
        <field name="name">ai.studio.model.preset.form</field>
        <field name="model">ai.studio.model.preset</field>
        <field name="arch" type="xml">
            <form string="Manken Preseti">
                <header>
                    <button name="action_generate_mannequin"
                            string="🤖 AI ile Manken Oluştur" type="object"
                            class="btn-primary"
                            invisible="mannequin_generation_state == 'generating'"
                            confirm="fal.ai ile manken fotoğrafı oluşturulsun mu? (API ücreti uygulanır)"/>
                    <button name="action_save_to_library"
                            string="📚 Kütüphaneye Kaydet" type="object"
                            class="btn-secondary"/>
                    <field name="mannequin_generation_state" widget="statusbar"
                           statusbar_visible="idle,generating,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Preset adi..."/></h1>
                    </div>
                    <group>
                        <group string="Manken Gorselleri">
                            <field name="model_image_front" widget="image" class="oe_avatar ais-zoomable-img"/>
                            <field name="model_image_back" widget="image" class="oe_avatar ais-zoomable-img"/>
                            <field name="model_image_side" widget="image" class="oe_avatar ais-zoomable-img"/>
                            <field name="preview_image" widget="image" class="oe_avatar ais-zoomable-img"/>
                        </group>
                        <group string="Ozellikler">
                            <field name="gender"/>
                            <field name="body_type"/>
                            <field name="garment_type"/>
                            <field name="target_audience"/>
                            <field name="age_range"/>
                            <field name="background_type"/>
                            <field name="library_mannequin_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="AI Manken Olusturma">
                        <field name="mannequin_prompt"
                               placeholder="Orn: Young woman, 25 years old, slim build, long brown hair, natural makeup, elegant standing pose, white studio background, fashion model, professional photography"
                               widget="text"/>
                    </group>
                    <group>
                        <group string="Stil ve Prompt">
                            <field name="style_notes" placeholder="Stil aciklamasi..."/>
                            <field name="default_prompt" placeholder="Varsayilan ek prompt..."/>
                        </group>
                        <group string="Kategoriler">
                            <field name="category_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
