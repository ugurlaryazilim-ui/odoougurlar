<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="view_ai_studio_session_list" model="ir.ui.view">
        <field name="name">ai.studio.session.list</field>
        <field name="model">ai.studio.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="state" widget="badge"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ai_studio_session_form" model="ir.ui.view">
        <field name="name">ai.studio.session.form</field>
        <field name="model">ai.studio.session</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_photos_ready" string="Fotograflar Hazir"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start_processing" string="AI Islemeyi Baslat"
                            type="object" class="btn-primary"
                            invisible="state != 'photos_ready'"
                            confirm="AI isleme baslatilsin mi?"/>
                    <button name="action_mark_done" string="Tamamla ve Kaydet"
                            type="object" class="btn-primary"
                            invisible="state != 'review'"/>
                    <button name="action_cancel" string="Iptal"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="Taslaga Don"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,photos_ready,processing,review,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="apply_to_siblings"/>
                        </group>
                        <group>
                            <field name="model_preset_id"/>
                            <field name="category"/>
                            <field name="quality_mode"/>
                            <field name="prompt_template_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="extra_prompt"/>
                    </group>
                    <notebook>
                        <page string="Fotograflar" name="photos">
                            <field name="photo_ids">
                                <list editable="bottom">
                                    <field name="photo_type"/>
                                    <field name="image_original" widget="image" width="120" class="ais-zoomable-img"/>
                                    <field name="image_processed" widget="image" width="120" class="ais-zoomable-img"/>
                                    <field name="quality_score"/>
                                    <field name="sequence" widget="handle"/>
                                </list>
                            </field>
                        </page>
                        <page string="AI Uretimler" name="generations">
                            <field name="generation_ids">
                                <list>
                                    <field name="photo_type"/>
                                    <field name="state" widget="badge"/>
                                    <field name="is_approved"/>
                                    <field name="is_primary"/>
                                    <field name="revision_number"/>
                                    <field name="cost" widget="monetary"/>
                                    <field name="generation_time_seconds"/>
                                    <field name="error_message" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Istatistikler" name="stats">
                            <group>
                                <group>
                                    <field name="total_cost" widget="monetary"/>
                                    <field name="revision_count"/>
                                    <field name="approval_rate"/>
                                </group>
                                <group>
                                    <field name="user_id"/>
                                    <field name="reviewer_id"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ai_studio_session_search" model="ir.ui.view">
        <field name="name">ai.studio.session.search</field>
        <field name="model">ai.studio.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <filter string="Taslak" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Onay Bekliyor" name="review" domain="[('state', '=', 'review')]"/>
                <filter string="Tamamlandi" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Durum" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Operator" name="group_user" context="{'group_by': 'user_id'}"/>
            </search>
        </field>
    </record>

</odoo>

