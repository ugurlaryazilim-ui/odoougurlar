<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ═══════════════ Root Action ═══════════════ -->
    <t t-name="ugurlar_tailor.TailorAction">
        <div class="tailor-app">
            <TailorMainMenu t-if="state.screen === 'main_menu'" onNavigate.bind="switchScreen"/>
            <TailorNewOrder t-if="state.screen === 'new_order'" onNavigate.bind="switchScreen"/>
            <TailorOrderList t-if="state.screen === 'order_list'" onNavigate.bind="switchScreen"/>
        </div>
    </t>

    <!-- ═══════════════ Main Menu ═══════════════ -->
    <t t-name="ugurlar_tailor.TailorMainMenu">
        <div class="tailor-screen tailor-main-menu">
            <div class="tailor-header">
                <h1>✂️ Terzi Takip</h1>
                <p class="tailor-subtitle">Mağaza Terzi Yönetim Sistemi</p>
            </div>
            <div class="tailor-menu-grid">
                <div class="tailor-menu-card tailor-card-primary" t-on-click="onNewOrder">
                    <div class="tailor-card-icon">📋</div>
                    <div class="tailor-card-title">Yeni Sipariş</div>
                    <div class="tailor-card-desc">Fatura arayın ve terzi siparişi oluşturun</div>
                </div>
                <div class="tailor-menu-card tailor-card-secondary" t-on-click="onOrderList">
                    <div class="tailor-card-icon">📦</div>
                    <div class="tailor-card-title">Sipariş Listesi</div>
                    <div class="tailor-card-desc">Tüm siparişleri görüntüleyin ve yönetin</div>
                </div>
            </div>
        </div>
    </t>

    <!-- ═══════════════ New Order ═══════════════ -->
    <t t-name="ugurlar_tailor.TailorNewOrder">
        <div class="tailor-screen tailor-new-order">
            <div class="tailor-toolbar">
                <button class="tailor-btn tailor-btn-back" t-on-click="goBack">← Geri</button>
                <h2 t-if="state.step === 1">Fatura Ara</h2>
                <h2 t-if="state.step === 2">Ürün ve Hizmet Seç</h2>
            </div>

            <!-- Step 1: Fatura Arama -->
            <div t-if="state.step === 1" class="tailor-step">
                <div class="tailor-search-box">
                    <input type="text" class="tailor-input"
                           placeholder="Fatura numarası giriniz..."
                           t-model="state.searchQuery"
                           t-on-keydown="onSearchKeydown"/>
                    <button class="tailor-btn tailor-btn-primary" t-on-click="searchInvoice"
                            t-att-disabled="state.searching">
                        <t t-if="state.searching">Aranıyor...</t>
                        <t t-else="">🔍 Ara</t>
                    </button>
                </div>
                <div t-if="state.invoices.length > 1" class="tailor-invoice-list">
                    <t t-foreach="state.invoices" t-as="inv" t-key="inv.invoice_no">
                        <div class="tailor-invoice-card" t-on-click="() => this.selectInvoice(inv.invoice_no)">
                            <strong t-esc="inv.invoice_no"/>
                            <span class="tailor-invoice-meta">
                                <t t-esc="inv.customer_name"/> — <t t-esc="inv.sales_person || '-'"/>
                            </span>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Step 2: Ürün + Hizmet Seçimi -->
            <div t-if="state.step === 2" class="tailor-step">
                <div class="tailor-invoice-info">
                    <strong>Fatura:</strong> <t t-esc="state.selectedInvoice.invoice_no"/> |
                    <strong>Müşteri:</strong> <t t-esc="state.selectedInvoice.customer_name"/> |
                    <strong>Satış Pers.:</strong> <t t-esc="state.selectedInvoice.sales_person || '-'"/>
                </div>

                <div class="tailor-items">
                    <t t-foreach="state.selectedInvoice.items || []" t-as="item" t-key="item.barcode">
                        <div class="tailor-item-card">
                            <div class="tailor-item-header">
                                <strong><t t-esc="item.product_code || item.barcode"/></strong>
                                <span class="tailor-item-barcode">Barkod: <t t-esc="item.barcode"/></span>
                            </div>

                            <!-- Terzi Seçimi -->
                            <div class="tailor-item-row">
                                <label>Terzi:</label>
                                <select class="tailor-select" t-on-change="(ev) => this.onTailorChange(item.barcode, ev)">
                                    <option value="">-- Terzi Seçin --</option>
                                    <t t-foreach="state.tailors" t-as="tailor" t-key="tailor.id">
                                        <option t-att-value="tailor.id" t-esc="tailor.name"/>
                                    </t>
                                </select>
                            </div>

                            <!-- Hizmet Seçimi -->
                            <div class="tailor-item-services">
                                <label>Hizmetler:</label>
                                <div class="tailor-service-grid">
                                    <t t-foreach="state.services" t-as="svc" t-key="svc.id">
                                        <label class="tailor-service-check">
                                            <input type="checkbox"
                                                   t-on-change="() => this.onServiceToggle(item.barcode, svc.id)"
                                                   t-att-checked="(state.itemSelections[item.barcode]?.service_ids || []).includes(svc.id)"/>
                                            <span>
                                                <t t-esc="svc.name"/>
                                                (<t t-esc="this.getServicePrice(svc.id, state.itemSelections[item.barcode]?.tailor_id).toFixed(2)"/> TL)
                                            </span>
                                        </label>
                                    </t>
                                </div>
                            </div>

                            <!-- Not -->
                            <div class="tailor-item-row">
                                <input type="text" class="tailor-input tailor-input-sm"
                                       placeholder="Not ekleyin..."
                                       t-on-change="(ev) => this.onNotesChange(item.barcode, ev)"/>
                            </div>

                            <!-- Toplam -->
                            <div class="tailor-item-total">
                                Toplam: <strong><t t-esc="this.getItemTotal(item.barcode).toFixed(2)"/> TL</strong>
                            </div>
                        </div>
                    </t>
                </div>

                <div class="tailor-submit-bar">
                    <button class="tailor-btn tailor-btn-success tailor-btn-lg"
                            t-on-click="submitOrders"
                            t-att-disabled="state.submitting">
                        <t t-if="state.submitting">Oluşturuluyor...</t>
                        <t t-else="">✅ Siparişleri Oluştur</t>
                    </button>
                </div>
            </div>
        </div>
    </t>

    <!-- ═══════════════ Order List ═══════════════ -->
    <t t-name="ugurlar_tailor.TailorOrderList">
        <div class="tailor-screen tailor-order-list">
            <div class="tailor-toolbar">
                <button class="tailor-btn tailor-btn-back" t-on-click="goBack">← Geri</button>
                <h2>Sipariş Listesi</h2>
            </div>

            <!-- Filtreler -->
            <div class="tailor-filters">
                <input type="text" class="tailor-input" placeholder="Ara (fatura, müşteri, sipariş no)..."
                       t-model="state.search" t-on-keydown="onSearchKeydown"/>
                <select class="tailor-select" t-on-change="onFilterChange">
                    <option value="">Tümü</option>
                    <option value="pending">Bekliyor</option>
                    <option value="in_progress">Terzide</option>
                    <option value="completed">Hazır</option>
                    <option value="delivered">Teslim</option>
                </select>
            </div>

            <!-- Loading -->
            <div t-if="state.loading" class="tailor-loading">Yükleniyor...</div>

            <!-- Liste -->
            <div t-if="!state.loading" class="tailor-orders">
                <div t-if="state.orders.length === 0" class="tailor-empty">
                    Sipariş bulunamadı.
                </div>
                <t t-foreach="state.orders" t-as="order" t-key="order.id">
                    <div class="tailor-order-card">
                        <div class="tailor-order-header">
                            <strong t-esc="order.name"/>
                            <span t-att-class="'tailor-badge ' + getStatusClass(order.state)"
                                  t-esc="getStatusLabel(order.state)"/>
                        </div>
                        <div class="tailor-order-body">
                            <div>📄 <t t-esc="order.invoice_no"/> — <t t-esc="order.product_name"/></div>
                            <div>👤 <t t-esc="order.customer_name"/></div>
                            <div t-if="order.tailor_id">✂️ <t t-esc="order.tailor_id[1]"/></div>
                            <div>💰 <t t-esc="order.total_price?.toFixed(2)"/> TL</div>
                            <div t-if="order.services and order.services.length" class="tailor-order-services">
                                <t t-foreach="order.services" t-as="s" t-key="s.id">
                                    <span class="tailor-service-tag" t-esc="s.service_name"/>
                                </t>
                            </div>
                        </div>
                        <div class="tailor-order-actions" t-if="getNextStatus(order.state)">
                            <button class="tailor-btn tailor-btn-sm tailor-btn-primary"
                                    t-on-click="() => this.updateStatus(order.id, this.getNextStatus(order.state))">
                                → <t t-esc="getStatusLabel(getNextStatus(order.state))"/>
                            </button>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Pagination -->
            <div class="tailor-pagination" t-if="state.total > state.limit">
                <button class="tailor-btn tailor-btn-sm" t-on-click="prevPage"
                        t-att-disabled="state.page <= 1">◀ Önceki</button>
                <span><t t-esc="state.page"/> / <t t-esc="totalPages"/></span>
                <button class="tailor-btn tailor-btn-sm" t-on-click="nextPage"
                        t-att-disabled="state.page >= totalPages">Sonraki ▶</button>
            </div>
        </div>
    </t>

</templates>
