<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="report_tailor_label">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <!-- ══════ NUSHA 1: TERZI ══════ -->
                    <div class="page tailor-label">
                        <t t-call="ugurlar_tailor.report_tailor_label_body">
                            <t t-set="copy_title">TERZI NUSHASI</t>
                            <t t-set="copy_color">#e74c3c</t>
                            <t t-set="copy_note">Bu nusha terzide kalir</t>
                        </t>
                    </div>

                    <!-- ══════ NUSHA 2: MAGAZA ══════ -->
                    <div class="page tailor-label">
                        <t t-call="ugurlar_tailor.report_tailor_label_body">
                            <t t-set="copy_title">MAGAZA NUSHASI</t>
                            <t t-set="copy_color">#2980b9</t>
                            <t t-set="copy_note">Urunle birlikte magazaya doner</t>
                        </t>
                    </div>

                    <!-- ══════ NUSHA 3: MUSTERI ══════ -->
                    <div class="page tailor-label">
                        <t t-call="ugurlar_tailor.report_tailor_label_body">
                            <t t-set="copy_title">MUSTERI NUSHASI</t>
                            <t t-set="copy_color">#27ae60</t>
                            <t t-set="copy_note">Bu nusha musteride kalir</t>
                        </t>
                    </div>
                </t>
            </t>
        </template>

        <!-- ══════ ETIKET GOVDESI (ORTAK SABLON) ══════ -->
        <template id="report_tailor_label_body">
            <style>
                .tailor-label {
                    font-family: 'Courier New', monospace;
                    font-size: 11px;
                    width: 76mm;
                    padding: 0;
                    margin: 0 auto;
                    color: #000;
                    line-height: 1.3;
                }
                .label-header {
                    text-align: center;
                    padding: 4px 0;
                    margin-bottom: 4px;
                    color: #fff;
                    font-weight: bold;
                    font-size: 14px;
                    letter-spacing: 1px;
                }
                .label-store {
                    text-align: center;
                    font-size: 13px;
                    font-weight: bold;
                    margin-bottom: 2px;
                }
                .label-divider {
                    border-top: 1px dashed #000;
                    margin: 3px 0;
                }
                .label-row {
                    display: flex;
                    justify-content: space-between;
                    padding: 1px 0;
                }
                .label-row .lbl {
                    font-weight: bold;
                    min-width: 80px;
                }
                .label-row .val {
                    text-align: right;
                    flex: 1;
                }
                .label-services {
                    margin: 2px 0;
                }
                .label-services .svc-item {
                    display: flex;
                    justify-content: space-between;
                    padding: 1px 4px;
                }
                .label-total {
                    font-size: 14px;
                    font-weight: bold;
                    text-align: right;
                    padding: 4px 0;
                    border-top: 2px solid #000;
                    border-bottom: 2px solid #000;
                    margin: 3px 0;
                }
                .label-barcode {
                    text-align: center;
                    margin: 4px 0;
                }
                .label-footer {
                    text-align: center;
                    font-size: 9px;
                    color: #666;
                    margin-top: 2px;
                    font-style: italic;
                }
                .label-date {
                    text-align: center;
                    font-size: 10px;
                    margin-top: 2px;
                }
            </style>

            <!-- NUSHA BASLIGI -->
            <div class="label-header" t-attf-style="background-color: #{copy_color};">
                <t t-out="copy_title"/>
            </div>

            <!-- MAGAZA ADI -->
            <div class="label-store">UGURLAR</div>
            <div style="text-align:center; font-size:10px;">Terzi Takip Sistemi</div>

            <div class="label-divider"/>

            <!-- SIPARIS NO -->
            <div class="label-row">
                <span class="lbl">Siparis No:</span>
                <span class="val" style="font-size:13px; font-weight:bold;">
                    <t t-out="o.name"/>
                </span>
            </div>

            <!-- FATURA NO -->
            <div class="label-row">
                <span class="lbl">Fatura No:</span>
                <span class="val"><t t-out="o.invoice_no"/></span>
            </div>

            <div class="label-divider"/>

            <!-- MUSTERI -->
            <div class="label-row">
                <span class="lbl">Musteri:</span>
                <span class="val"><t t-out="o.customer_name"/></span>
            </div>
            <t t-if="o.customer_phone">
                <div class="label-row">
                    <span class="lbl">Telefon:</span>
                    <span class="val"><t t-out="o.customer_phone"/></span>
                </div>
            </t>
            <t t-if="o.sales_person">
                <div class="label-row">
                    <span class="lbl">Satis Per.:</span>
                    <span class="val"><t t-out="o.sales_person"/></span>
                </div>
            </t>

            <div class="label-divider"/>

            <!-- URUN -->
            <div class="label-row">
                <span class="lbl">Urun:</span>
                <span class="val"><t t-out="o.product_code or o.product_name"/></span>
            </div>
            <div class="label-row">
                <span class="lbl">Barkod:</span>
                <span class="val"><t t-out="o.product_barcode"/></span>
            </div>

            <div class="label-divider"/>

            <!-- TERZI -->
            <div class="label-row">
                <span class="lbl">Terzi:</span>
                <span class="val" style="font-weight:bold;">
                    <t t-out="o.tailor_id.name"/>
                </span>
            </div>

            <div class="label-divider"/>

            <!-- HIZMETLER -->
            <div style="font-weight:bold; text-align:center; padding:2px 0;">YAPILACAK ISLEMLER</div>
            <div class="label-services">
                <t t-foreach="o.line_ids" t-as="line">
                    <div class="svc-item">
                        <span><t t-out="line.service_name"/></span>
                        <span><t t-out="'%.2f TL' % line.price"/></span>
                    </div>
                </t>
            </div>

            <!-- TOPLAM -->
            <div class="label-total">
                TOPLAM: <t t-out="'%.2f TL' % o.total_price"/>
            </div>

            <!-- BARKOD -->
            <div class="label-barcode">
                <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=1' % ('Code128', o.name, 300, 50)" alt="Barkod"/>
            </div>

            <!-- TARIH -->
            <div class="label-date">
                <t t-out="o.create_date.strftime('%d.%m.%Y %H:%M')"/>
            </div>

            <!-- NUSHA NOTU -->
            <div class="label-footer">
                <t t-out="copy_note"/>
            </div>

            <t t-if="o.notes">
                <div class="label-divider"/>
                <div style="font-size:10px;">
                    <strong>Not:</strong> <t t-out="o.notes"/>
                </div>
            </t>
        </template>
    </data>
</odoo>
