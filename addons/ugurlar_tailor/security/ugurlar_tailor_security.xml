<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Terzi Kullanici Grubu -->
        <record id="group_tailor_user" model="res.groups">
            <field name="name">Terzi / Kullanici</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Terzi Yonetici Grubu -->
        <record id="group_tailor_manager" model="res.groups">
            <field name="name">Terzi / Yonetici</field>
            <field name="implied_ids" eval="[(4, ref('group_tailor_user'))]"/>
        </record>
    </data>
</odoo>
