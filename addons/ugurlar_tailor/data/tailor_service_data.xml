<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sipariş numarası sequence -->
        <record id="seq_tailor_order" model="ir.sequence">
            <field name="name">Terzi Sipariş Numarası</field>
            <field name="code">ugurlar.tailor.order</field>
            <field name="prefix">TRZ-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Varsayılan Terzi Hizmetleri -->
        <record id="service_paca_kisaltma" model="ugurlar.tailor.service">
            <field name="name">Paça Kısaltma</field>
            <field name="price">50.00</field>
            <field name="sequence">1</field>
        </record>
        <record id="service_bel_daraltma" model="ugurlar.tailor.service">
            <field name="name">Bel Daraltma</field>
            <field name="price">75.00</field>
            <field name="sequence">2</field>
        </record>
        <record id="service_boy_kisaltma" model="ugurlar.tailor.service">
            <field name="name">Boy Kısaltma</field>
            <field name="price">60.00</field>
            <field name="sequence">3</field>
        </record>
        <record id="service_kol_kisaltma" model="ugurlar.tailor.service">
            <field name="name">Kol Kısaltma</field>
            <field name="price">45.00</field>
            <field name="sequence">4</field>
        </record>
        <record id="service_fermuar_degisimi" model="ugurlar.tailor.service">
