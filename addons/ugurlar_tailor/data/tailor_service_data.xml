            <field name="price">100.00</field>
            <field name="sequence">8</field>
        </record>
        <record id="service_beden_buyutme" model="ugurlar.tailor.service">
            <field name="name">Beden Büyütme</field>
            <field name="price">110.00</field>
            <field name="sequence">9</field>
        </record>
        <record id="service_yirtik_onarim" model="ugurlar.tailor.service">
            <field name="name">Yırtık Onarım</field>
            <field name="price">35.00</field>
            <field name="sequence">10</field>
        </record>
    </data>
</odoo>
