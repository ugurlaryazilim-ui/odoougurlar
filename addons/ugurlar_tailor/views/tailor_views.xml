<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ═══════════════ Terzi List View ═══════════════ -->
    <record id="view_ugurlar_tailor_list" model="ir.ui.view">
        <field name="name">ugurlar.tailor.list</field>
        <field name="model">ugurlar.tailor</field>
        <field name="arch" type="xml">
            <list string="Terziler">
                <field name="name"/>
                <field name="phone"/>
                <field name="order_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════ Terzi Form View ═══════════════ -->
    <record id="view_ugurlar_tailor_form" model="ir.ui.view">
        <field name="name">ugurlar.tailor.form</field>
        <field name="model">ugurlar.tailor</field>
        <field name="arch" type="xml">
            <form string="Terzi">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-scissors">
                            <field name="order_count" widget="statinfo" string="Siparis"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Arşivlenmiş" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Özel Fiyatlar" name="prices">
                            <field name="price_ids">
                                <list editable="bottom">
                                    <field name="service_id"/>
                                    <field name="price"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notlar" name="notes">
                            <field name="note" placeholder="Terzi hakkında notlar..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════ Terzi Search View ═══════════════ -->
    <record id="view_ugurlar_tailor_search" model="ir.ui.view">
        <field name="name">ugurlar.tailor.search</field>
        <field name="model">ugurlar.tailor</field>
        <field name="arch" type="xml">
            <search string="Terzi Ara">
                <field name="name"/>
                <field name="phone"/>
                <filter string="Aktif" name="active" domain="[('active', '=', True)]"/>
                <filter string="Arşivlenmiş" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ═══════════════ Terzi Action ═══════════════ -->
    <record id="action_ugurlar_tailor" model="ir.actions.act_window">
        <field name="name">Terziler</field>
        <field name="res_model">ugurlar.tailor</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                İlk terzinizi ekleyin!
            </p>
            <p>Dış atölyelerinizi veya terzi kişilerinizi buradan yönetebilirsiniz.</p>
        </field>
    </record>
</odoo>
