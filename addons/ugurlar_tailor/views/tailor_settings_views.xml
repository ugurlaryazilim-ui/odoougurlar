<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tailor_settings" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.ugurlar.tailor</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Terzi Takip" string="Terzi Takip" name="ugurlar_tailor" groups="base.group_system">
                        <block title="Nebim MSSQL Baglanti Ayarlari" name="tailor_mssql_settings">
                            <setting string="SQL Server Adresi" help="Nebim SQL Server IP veya hostname">
                                <div class="content-group">
                                    <field name="tailor_mssql_server" placeholder="192.168.0.225"/>
                                </div>
                            </setting>
                            <setting string="SQL Port" help="SQL Server port numarasi">
                                <div class="content-group">
                                    <field name="tailor_mssql_port"/>
                                </div>
                            </setting>
                            <setting string="SQL Veritabani" help="Nebim veritabani adi">
                                <div class="content-group">
                                    <field name="tailor_mssql_database" placeholder="UGURLAR"/>
                                </div>
                            </setting>
                            <setting string="View / Tablo Adi" help="Fatura verilerinin cekilecegi view adi">
                                <div class="content-group">
                                    <field name="tailor_mssql_view_name" placeholder="dbo.vw_TerziFaturalar"/>
                                </div>
                            </setting>
                            <setting string="SQL Kullanici Adi" help="SQL Server kullanici adi">
                                <div class="content-group">
                                    <field name="tailor_mssql_user" placeholder="kadri"/>
                                </div>
                            </setting>
                            <setting string="SQL Sifre" help="SQL Server sifresi">
                                <div class="content-group">
                                    <field name="tailor_mssql_password" password="True"/>
                                </div>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
