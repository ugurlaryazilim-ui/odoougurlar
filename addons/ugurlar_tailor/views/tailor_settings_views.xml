<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_tailor_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ugurlar.tailor</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Terzi Takip" string="Terzi Takip" name="ugurlar_tailor" groups="base.group_system">
                    <block title="Nebim MSSQL Baglantisi" name="tailor_mssql_settings">
                        <setting string="SQL Server Baglantisi" help="Terzi fatura verilerinin cekilecegi Nebim SQL Server ayarlari">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="tailor_mssql_server" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="tailor_mssql_server" placeholder="192.168.0.100"/>
                                </div>
                                <div class="row">
                                    <label for="tailor_mssql_port" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="tailor_mssql_port"/>
                                </div>
                                <div class="row">
                                    <label for="tailor_mssql_database" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="tailor_mssql_database" placeholder="NEBIM_DB"/>
                                </div>
                                <div class="row">
                                    <label for="tailor_mssql_user" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="tailor_mssql_user" placeholder="sa"/>
                                </div>
                                <div class="row">
                                    <label for="tailor_mssql_password" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="tailor_mssql_password" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="tailor_mssql_view_name" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="tailor_mssql_view_name" placeholder="vw_TerziFaturalar"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
