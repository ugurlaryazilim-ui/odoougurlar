<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="idefix_sale_order_form" model="ir.ui.view">
        <field name="name">idefix.sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Idefix" name="idefix_integration" invisible="not idefix_order_id">
                    <group>
                        <field name="idefix_store_id"/>
                        <field name="idefix_order_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
