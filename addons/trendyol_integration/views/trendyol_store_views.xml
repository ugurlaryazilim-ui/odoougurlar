<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- MAĞAZA FORM VIEW                                    -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="trendyol_store_form" model="ir.ui.view">
        <field name="name">trendyol.store.form</field>
        <field name="model">trendyol.store</field>
        <field name="arch" type="xml">
            <form string="Trendyol Mağaza">
                <header>
                    <button name="action_test_connection" type="object"
                            string="🔌 Bağlantı Test Et" class="btn-primary"/>
                    <button name="action_sync_now" type="object"
                            string="🔄 Şimdi Senkronize Et" class="btn-secondary"/>
                    <button name="action_sync_financials" type="object"
                            string="💰 Finansal Senkron" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="order_count" widget="statinfo" string="Sipariş"/>
                        </button>
                        <button name="action_view_settlements" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <field name="settlement_count" widget="statinfo" string="Finansal"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Arşiv" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Mağaza Adı"/></h1>
                    </div>

                    <notebook>
                        <!-- ── API Bağlantı ── -->
                        <page string="API Bağlantı" name="api">
                            <group>
                                <group string="API Bağlantı Bilgileri">
                                    <field name="api_key"/>
                                    <field name="api_secret" password="True"/>
                                    <field name="seller_id"/>
                                    <field name="environment"/>
                                </group>
                                <group string="Senkronizasyon">
                                    <field name="auto_sync"/>
                                    <field name="sync_interval" invisible="not auto_sync"/>
                                    <field name="last_sync"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Sipariş Ayarları ── -->
                        <page string="Sipariş Ayarları" name="order_settings">
                            <group>
                                <group string="Sipariş İşleme">
                                    <field name="auto_confirm"/>
                                    <field name="auto_cancel"/>
                                    <field name="order_day_range"/>
                                    <field name="order_ref_type"/>
                                </group>
                                <group string="Komisyon">
                                    <field name="process_commission"/>
                                </group>
                            </group>
                            <group>
                                <group string="İade Ayarları">
                                    <field name="process_returns"/>
                                    <field name="return_day_range" invisible="not process_returns"/>
                                </group>
                                <group string="Müşteri Ayarları">
                                    <field name="customer_prefix"/>
                                    <field name="micro_export_prefix"/>
                                    <field name="skip_customer_email"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Kargo Ayarları ── -->
                        <page string="Kargo Ayarları" name="cargo_settings">
                            <group>
                                <group string="Kargo Kodu">
                                    <field name="auto_send_cargo"/>
                                    <field name="cargo_include_order_number"/>
                                </group>
                                <group string="Koli Bilgisi">
                                    <field name="default_package_count"/>
                                    <field name="default_desi"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Finansal İşlemler ── -->
                        <page string="Finansal İşlemler" name="financial_settings">
                            <group>
                                <group string="Finansal Senkronizasyon">
                                    <field name="sync_financials"/>
                                    <field name="financial_day_range"
                                           invisible="not sync_financials"/>
                                    <field name="last_financial_sync"/>
                                </group>
                                <group string="Tahmini Hesaplama (Fatura kesilmemişse)">
                                    <field name="platform_fee_rate"/>
                                    <field name="cargo_unit_price"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Diğer ── -->
                        <page string="Diğer" name="other">
                            <group>
                                <group>
                                    <field name="sequence"/>
                                    <field name="active"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- MAĞAZA LIST VIEW                                    -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="trendyol_store_list" model="ir.ui.view">
        <field name="name">trendyol.store.list</field>
        <field name="model">trendyol.store</field>
        <field name="arch" type="xml">
            <list string="Trendyol Mağazaları">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="seller_id"/>
                <field name="environment" widget="badge"
                       decoration-success="environment == 'prod'"
                       decoration-warning="environment == 'stage'"/>
                <field name="auto_sync"/>
                <field name="last_sync"/>
                <field name="order_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- MAĞAZA KANBAN VIEW                                  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="trendyol_store_kanban" model="ir.ui.view">
        <field name="name">trendyol.store.kanban</field>
        <field name="model">trendyol.store</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="seller_id"/>
                <field name="order_count"/>
                <field name="last_sync"/>
                <field name="active"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>Seller ID: <field name="seller_id"/></div>
                                <div><field name="order_count"/> sipariş</div>
                                <div t-if="record.last_sync.raw_value">
                                    Son senkron: <field name="last_sync"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- MAĞAZA SEARCH VIEW                                  -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="trendyol_store_search" model="ir.ui.view">
        <field name="name">trendyol.store.search</field>
        <field name="model">trendyol.store</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="seller_id"/>
                <filter string="Aktif" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Arşiv" name="filter_archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- MAĞAZA ACTION                                       -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="action_trendyol_stores" model="ir.actions.act_window">
        <field name="name">Mağazalar</field>
        <field name="res_model">trendyol.store</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="trendyol_store_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Henüz Trendyol mağazası yok</p>
            <p>Yeni bir mağaza ekleyerek Trendyol entegrasyonuna başlayın.</p>
        </field>
    </record>

</odoo>
