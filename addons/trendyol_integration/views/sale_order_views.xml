<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sale Order Form — Trendyol bilgi alanları -->
    <record id="sale_order_form_trendyol" model="ir.ui.view">
        <field name="name">sale.order.form.trendyol</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="trendyol_order_id" invisible="not trendyol_order_id"/>
                <field name="trendyol_order_number" invisible="not trendyol_order_id"/>
                <field name="trendyol_store_id" invisible="not trendyol_order_id"/>
                <field name="trendyol_status" widget="badge" invisible="not trendyol_order_id"
                       decoration-success="trendyol_status in ('delivered', 'shipped')"
                       decoration-warning="trendyol_status in ('created', 'picking')"
                       decoration-info="trendyol_status == 'invoiced'"
                       decoration-danger="trendyol_status in ('cancelled', 'unsupplied', 'returned')"/>
            </xpath>
        </field>
    </record>

    <!-- Sale Order List — Trendyol kolonları -->
    <record id="sale_order_tree_trendyol" model="ir.ui.view">
        <field name="name">sale.order.tree.trendyol</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="trendyol_order_number" optional="hide"/>
                <field name="trendyol_store_name" optional="hide"/>
                <field name="trendyol_seller_id" optional="hide"/>
                <field name="trendyol_status" widget="badge" optional="hide"
                       decoration-success="trendyol_status in ('delivered', 'shipped')"
                       decoration-warning="trendyol_status in ('created', 'picking')"
                       decoration-danger="trendyol_status in ('cancelled', 'unsupplied')"/>
            </xpath>
        </field>
    </record>

</odoo>
