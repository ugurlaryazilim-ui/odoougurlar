<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_marketplace_mapping_tree" model="ir.ui.view">
        <field name="name">odoougurlar.marketplace.mapping.tree</field>
        <field name="model">odoougurlar.marketplace.mapping</field>
        <field name="arch" type="xml">
            <list string="Pazaryeri Eşleştirmeleri">
                <field name="name"/>
                <field name="marketplace"/>
                <field name="country_id"/>
                <field name="nebim_customer_code"/>
                <field name="nebim_order_model_type"/>
                <field name="nebim_invoice_model_type"/>
            </list>
        </field>
    </record>

    <record id="view_marketplace_mapping_form" model="ir.ui.view">
        <field name="name">odoougurlar.marketplace.mapping.form</field>
        <field name="model">odoougurlar.marketplace.mapping</field>
        <field name="arch" type="xml">
            <form string="Pazaryeri Eşleştirmesi">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Örn: Trendyol Azerbaycan İhracat Kuralları"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Hedef Pazaryeri">
                            <field name="marketplace"/>
                            <field name="country_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Müşteri ve Fiş Tanımı">
                            <field name="nebim_customer_code"/>
                            <field name="nebim_order_model_type"/>
                            <field name="nebim_invoice_model_type"/>
                            <field name="export_type_code"/>
                            <field name="tax_exemption_code"/>
                        </group>
                    </group>
                    <group string="Ödeme Tahsilat Eşleştirmeleri (Fatura)">
                        <group>
                            <field name="bank_code"/>
                            <field name="sales_advance_code"/>
                        </group>
                        <group>
                            <field name="credit_card_type_code"/>
                            <field name="credit_card_desc"/>
                            <field name="sales_person_code"/>
                        </group>
                    </group>
                    <group string="Teslimat ve Depo Ayarları">
                        <group>
                            <field name="delivery_company_code"/>
                            <field name="store_code"/>
                            <field name="warehouse_code"/>
                        </group>
                        <group>
                            <field name="payment_agent"/>
                            <field name="sales_url"/>
                            <field name="nebim_address_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_marketplace_mapping" model="ir.actions.act_window">
        <field name="name">Pazaryeri Muhasebe Eşleştirmeleri</field>
        <field name="res_model">odoougurlar.marketplace.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menüye Ekle (Nebim Ayarları altında) -->
    <menuitem id="menu_marketplace_mapping"
              name="Pazaryeri Muhasebe Kodları"
              parent="odoougurlar.menu_nebim_settings"
              action="action_marketplace_mapping"
              sequence="25"/>
</odoo>
