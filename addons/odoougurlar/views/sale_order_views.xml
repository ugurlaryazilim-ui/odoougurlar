<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_nebim" model="ir.ui.view">
        <field name="name">sale.order.form.nebim.ext</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Fatura Görüntüle butonu -->
            <xpath expr="//header" position="inside">
                <button name="action_view_earchive_invoice" type="object"
                        string="📄 Fatura Görüntüle"
                        class="btn-info"
                        invisible="invoice_count == 0"/>
                <button name="action_reprint_cargo_label" type="object"
                        string="🏷️ Yeniden Etiket Yazdır"
                        class="btn-warning"
                        invisible="invoice_count == 0"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Nebim Entegrasyonu" name="nebim_integration">
                    <group>
                        <group>
                            <field name="nebim_customer_sent"/>
                            <field name="nebim_customer_code" invisible="not nebim_customer_sent" widget="CopyClipboardChar"/>
                            <field name="nebim_order_sent"/>
                            <button name="action_reset_nebim"
                                    string="🔄 Nebim Sıfırla"
                                    type="object"
                                    class="btn-warning"
                                    invisible="not nebim_order_sent"
                                    confirm="Nebim sipariş ve fatura bayrakları sıfırlanacak. Nebim'deki eski siparişi sildiğinizden emin olun. Devam edilsin mi?"/>
                        </group>
                        <group>
                            <field name="nebim_order_response"/>
                            <field name="nebim_order_request"/>
                        </group>
                    </group>
                    <group string="Nebim Cari JSON">
                        <group>
                            <field name="nebim_customer_request"/>
                        </group>
                        <group>
                            <field name="nebim_customer_response"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Sipariş Listesi (Tree) — Tıkla-Kopyala özelliği -->
    <record id="view_order_tree_nebim" model="ir.ui.view">
        <field name="name">sale.order.tree.nebim.ext</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <!-- Numara (name) alanına tıkla-kopyala -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="widget">CopyClipboardChar</attribute>
            </xpath>
            <!-- Partner'dan sonra Nebim alanları ekle -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="nebim_customer_code" optional="show" string="Nebim Cari Kodu"
                       widget="CopyClipboardChar"/>
                <field name="picking_batch_names" optional="show" string="Rota"
                       widget="CopyClipboardChar"/>
                <field name="marketplace_name" optional="show" string="Pazaryeri"/>
                <field name="marketplace_order_number" optional="show" string="Sipariş No"
                       widget="CopyClipboardChar"/>
                <field name="marketplace_store_name" optional="show" string="Mağaza Adı"/>
                <field name="marketplace_seller_id" optional="show" string="Seller ID"/>
            </xpath>
        </field>
    </record>

    <record id="view_quotation_tree_nebim" model="ir.ui.view">
        <field name="name">sale.quotation.tree.nebim.ext</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="nebim_customer_code" optional="show" string="Nebim Cari Kodu"
                       widget="CopyClipboardChar"/>
                <field name="picking_batch_names" optional="show" string="Rota"
                       widget="CopyClipboardChar"/>
                <field name="marketplace_name" optional="show" string="Pazaryeri"/>
                <field name="marketplace_order_number" optional="show" string="Sipariş No"
                       widget="CopyClipboardChar"/>
                <field name="marketplace_store_name" optional="show" string="Mağaza Adı"/>
                <field name="marketplace_seller_id" optional="show" string="Seller ID"/>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ARAMA GENİŞLETME — Nebim, Sipariş No, Barkod      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="view_sale_order_search_nebim" model="ir.ui.view">
        <field name="name">sale.order.search.nebim.ext</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="arch" type="xml">
            <!-- Ana arama alanını genişlet — ne yazarsan yaz her yerde arasın -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Ara...</attribute>
                <attribute name="filter_domain">['|', '|', '|', '|',
                    ('name', 'ilike', self),
                    ('client_order_ref', 'ilike', self),
                    ('nebim_customer_code', 'ilike', self),
                    ('partner_id', 'child_of', self),
                    ('order_line.product_id.barcode', 'ilike', self)]</attribute>
            </xpath>
            <!-- Özel arama alanları da ekle (dropdown'dan seçmek isteyenler için) -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="nebim_customer_code" string="Nebim Cari Kodu"/>
                <field name="client_order_ref" string="Sipariş No"/>
                <field name="order_line" string="Ürün Barkodu"
                       filter_domain="[('order_line.product_id.barcode', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- VARSAYILAN FİLTRE KALDIRMA                         -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="sale.action_orders" model="ir.actions.act_window">
        <field name="context">{}</field>
    </record>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SATIŞ MENÜSÜ — Siparişler varsayılan olarak açılır -->
    <!-- ═══════════════════════════════════════════════════ -->
    <record id="sale.menu_sale_order" model="ir.ui.menu">
        <field name="sequence">1</field>
    </record>
    <record id="sale.menu_sale_quotations" model="ir.ui.menu">
        <field name="sequence">2</field>
    </record>

</odoo>
