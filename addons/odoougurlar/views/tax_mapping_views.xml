<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tax_mapping_tree" model="ir.ui.view">
        <field name="name">odoougurlar.tax.mapping.tree</field>
        <field name="model">odoougurlar.tax.mapping</field>
        <field name="arch" type="xml">
            <list string="Vergi Dairesi Eşleştirmeleri">
                <field name="name"/>
                <field name="nebim_tax_office_code"/>
            </list>
        </field>
    </record>

    <record id="view_tax_mapping_form" model="ir.ui.view">
        <field name="name">odoougurlar.tax.mapping.form</field>
        <field name="model">odoougurlar.tax.mapping</field>
        <field name="arch" type="xml">
            <form string="Vergi Dairesi Eşleştirmesi">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Örn: osmangazi"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Nebim Bilgileri">
                            <field name="nebim_tax_office_code"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tax_mapping" model="ir.actions.act_window">
        <field name="name">Vergi No Map'lemeleri</field>
        <field name="res_model">odoougurlar.tax.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tax_mapping"
              name="Vergi No Map'lemeleri"
              parent="odoougurlar.menu_nebim_settings"
              action="action_tax_mapping"
              sequence="30"/>
</odoo>
