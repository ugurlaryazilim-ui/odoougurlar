<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        Stok Konumları list view — kontrol paneli butonları.
        Odoo 19 web.ListView template'ini inherit eder.
        o_list_button_add (Yeni) butonundan sonra eklenir.
    -->
    <t t-name="odoougurlar.StockLocationListView" t-inherit="web.ListView" owl="1">
        <xpath expr="//button[hasclass('o_list_button_add')]" position="after">
            <button type="button"
                    class="btn btn-secondary o_shelf_export_btn ms-1"
                    t-on-click="onExportShelfDetail">
                📦 Raf Detay Dosyası
            </button>
            <button type="button"
                    class="btn btn-secondary o_product_export_btn ms-1"
                    t-on-click="onExportProductList">
                📋 Ürün Listesi
            </button>
            <button type="button"
                    class="btn btn-primary o_transfer_order_btn ms-1"
                    t-on-click="onCreateTransfer">
                🚚 Transfer Siparişi
            </button>
        </xpath>
    </t>

</templates>
