<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Ürün Senkronizasyonu: Günde 1 kez (Günlük Mod) -->
        <record id="cron_product_sync" model="ir.cron">
            <field name="name">Uğurlar Nebim: Ürün Senkronizasyonu (Günlük)</field>
            <field name="model_id" ref="model_odoougurlar_nebim_service"/>
            <field name="state">code</field>
            <field name="code">model.sync_products()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

        <!-- Stok Güncelleme: Her 1 dakikada -->
        <record id="cron_stock_sync" model="ir.cron">
            <field name="name">Uğurlar Nebim: Stok Güncelleme (1dk)</field>
            <field name="model_id" ref="model_odoougurlar_nebim_service"/>
            <field name="state">code</field>
            <field name="code">model.sync_stock_prices(mode='incremental')</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <!-- Fatura Gönderimi: Her 30 dakikada -->
        <record id="cron_invoice_sync" model="ir.cron">
            <field name="name">Uğurlar Nebim: Fatura Gönderimi</field>
            <field name="model_id" ref="model_odoougurlar_nebim_service"/>
            <field name="state">code</field>
            <field name="code">model.sync_invoices()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

    </data>

    <!-- Kuyruk İşleyici: noupdate=0 çünkü upgrade'de oluşturulmalı -->
    <data noupdate="0">
        <record id="cron_process_product_queue" model="ir.cron">
            <field name="name">Uğurlar Nebim: Ürün Kuyruk İşleyici</field>
            <field name="model_id" ref="model_odoougurlar_product_queue"/>
            <field name="state">code</field>
            <field name="code">model.process_queue_batch()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Otomatik Ürün Senkronizasyonu: Saatte 1 kez -->
        <record id="cron_auto_product_sync" model="ir.cron">
            <field name="name">Uğurlar Nebim: Otomatik Ürün Senkronizasyonu</field>
            <field name="model_id" ref="model_odoougurlar_product_queue"/>
            <field name="state">code</field>
            <field name="code">model.auto_sync_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>

    <!-- Log Temizliği: Günde 1 kez -->
    <data noupdate="0">
        <record id="cron_log_cleanup" model="ir.cron">
            <field name="name">Uğurlar Nebim: Log Temizliği (Günlük)</field>
            <field name="model_id" ref="model_odoougurlar_sync_log"/>
            <field name="state">code</field>
            <field name="code">model.auto_cleanup_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
