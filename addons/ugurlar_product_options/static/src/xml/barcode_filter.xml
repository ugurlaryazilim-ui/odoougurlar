<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        ProductFilterListRenderer — web.ListRenderer'dan inherit.
        t-inherit-mode="primary" → sadece bu renderer kullanır.
        Sort ikonunun hemen yanına filtre ikonu ekler.
    -->
    <t t-name="ugurlar_product_options.ProductFilterListRenderer"
       t-inherit="web.ListRenderer" t-inherit-mode="primary" owl="1">

        <xpath expr="//i[contains(@class, 'o_list_sortable_icon')]" position="after">
            <i t-if="column and column.name and (column.name === 'barcode' or column.name === 'default_code')"
               class="fa fa-filter bf-icon"
               t-att-data-bf-field="column.name"
               t-att-title="column.name === 'barcode' ? 'Barkod Filtre' : 'İç Referans Filtre'"
               t-on-click.stop.prevent="onBfFilterClick"/>
        </xpath>

    </t>

</templates>
