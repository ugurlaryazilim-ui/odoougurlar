<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_flo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.flo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Flo" string="Flo" name="flo_integration" data-key="flo_integration" logo="/flo_integration/static/description/flo.png" icon="/flo_integration/static/description/flo.png">
                    <block title="Depo Ayarları" name="flo_warehouse">
                        <setting string="Sipariş Depoları" help="Siparişlerin düşeceği depolar (tüm mağazalar için geçerli)">
                            <div class="row mt16">
                                <label for="flo_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="flo_warehouse_id" class="col-4"/>
                            </div>
                            <div class="row">
                                <label for="flo_backup_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="flo_backup_warehouse_id" class="col-4"/>
                            </div>
                        </setting>
                    </block>
                    
                    <block title="Toplu Senkronizasyon" name="flo_sync">
                        <setting string="Tüm Mağazalar" help="Tüm aktif mağazalardan siparişleri senkronize et">
                            <div class="mt8">
                                <button name="action_flo_sync_all" icon="fa-refresh" type="object" string="Tüm Mağazaları Senkronize Et" class="btn-primary"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
