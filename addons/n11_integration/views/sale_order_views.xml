<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="n11_sale_order_form" model="ir.ui.view">
        <field name="name">n11.sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="N11" name="n11_integration" invisible="not n11_order_id">
                    <group>
                        <field name="n11_store_id"/>
                        <field name="n11_order_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
