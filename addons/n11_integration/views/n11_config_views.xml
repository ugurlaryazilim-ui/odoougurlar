<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_n11" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.n11</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="N11" string="N11" name="n11_integration" data-key="n11_integration" logo="/n11_integration/static/description/n11.png" icon="/n11_integration/static/description/n11.png">
                    <block title="Depo Ayarları" name="n11_warehouse">
                        <setting string="Sipariş Depoları" help="Siparişlerin düşeceği depolar (tüm mağazalar için geçerli)">
                            <div class="row mt16">
                                <label for="n11_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="n11_warehouse_id" class="col-4"/>
                            </div>
                            <div class="row">
                                <label for="n11_backup_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="n11_backup_warehouse_id" class="col-4"/>
                            </div>
                        </setting>
                    </block>
                    
                    <block title="Toplu Senkronizasyon" name="n11_sync">
                        <setting string="Tüm Mağazalar" help="Tüm aktif mağazalardan siparişleri senkronize et">
                            <div class="mt8">
                                <button name="action_n11_sync_all" icon="fa-refresh" type="object" string="Tüm Mağazaları Senkronize Et" class="btn-primary"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
