<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hepsiburada Ayarlar Action — context ile doğrudan Hepsiburada sekmesine gider -->
    <record id="action_hepsiburada_settings" model="ir.actions.act_window">
        <field name="name">Hepsiburada Ayarları</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'hepsiburada_integration'}</field>
    </record>

    <!-- Ana Odoo Ayarlarına (res.config.settings) Kısayol Ekleme -->
    <record id="res_config_settings_view_form_hepsiburada" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.hepsiburada</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Hepsiburada" string="Hepsiburada" name="hepsiburada_integration" data-key="hepsiburada_integration" logo="/hepsiburada_integration/static/description/hepsiburada.png" icon="/hepsiburada_integration/static/description/hepsiburada.png">
                    <block title="Depo Ayarları" name="hepsiburada_warehouse_block">
                        <setting string="Sipariş Depoları" help="Siparişlerin düşeceği depolar (tüm mağazalar için geçerli)">
                            <div class="row mt16">
                                <label for="hb_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="hb_warehouse_id" class="col-4"/>
                            </div>
                            <div class="row">
                                <label for="hb_backup_warehouse_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="hb_backup_warehouse_id" class="col-4"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    
</odoo>
