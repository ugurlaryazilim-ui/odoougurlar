<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ============================================================
             Ek Özellikler — Ayarlar Sayfası
             ============================================================ -->
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.ek_ozellikler</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="priority">90</field>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Ek Özellikler" string="Ek Özellikler" name="ek_ozellikler" data-key="ek_ozellikler" groups="base.group_system">

                        <block title="e-Ticaret Araçları" name="ecommerce_tools">
                            <setting string="Toplu e-Ticaret Yayınlama"
                                     help="Ürün listesinden seçili ürünleri tek tıkla e-ticarete yayınlayın. Aksiyonlar menüsünden '🛒 e-Ticarete Bağla' seçeneğini kullanın.">
                                <div class="mt8 text-muted">
                                    <strong>Kullanım:</strong> Stok → Ürünler → Seç → Aksiyonlar → 🛒 e-Ticarete Bağla
                                </div>
                            </setting>
                        </block>

                        <block title="Ürün Sayfası Görünümü" name="product_page_display">
                            <setting string="SKU (İç Referans) Göster"
                                     help="E-ticaret ürün detay sayfasında SKU bilgisini fiyatın altında gösterir. Renk/beden değişince dinamik güncellenir.">
                                <field name="show_sku_on_product_page"/>
                            </setting>

                            <setting string="Barkod Göster"
                                     help="E-ticaret ürün detay sayfasında barkod bilgisini fiyatın altında gösterir. Renk/beden değişince dinamik güncellenir.">
                                <field name="show_barcode_on_product_page"/>
                            </setting>
                        </block>

                    </app>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
