<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pazarama_sale_order_form" model="ir.ui.view">
        <field name="name">pazarama.sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Pazarama" name="pazarama_integration" invisible="not pazarama_order_id">
                    <group>
                        <field name="pazarama_store_id"/>
                        <field name="pazarama_order_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
