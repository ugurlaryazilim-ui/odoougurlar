<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_pazarama_config_settings" model="ir.actions.act_window">
        <field name="name">Pazarama Ayarları</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'pazarama_integration'}</field>
    </record>

    <!-- Ana Menü -->
    <menuitem id="menu_pazarama_root" name="Pazarama" web_icon="pazarama_integration,static/description/icon.png" sequence="60"/>

    <!-- Alt Menüler -->
    <menuitem id="menu_pazarama_stores" name="Mağazalar" parent="menu_pazarama_root" action="action_pazarama_store" sequence="10"/>
    <menuitem id="menu_pazarama_orders" name="Pazarama Siparişleri" parent="menu_pazarama_root" action="action_pazarama_orders" sequence="20"/>
    <menuitem id="menu_pazarama_settings" name="Ayarlar" parent="menu_pazarama_root" action="action_pazarama_config_settings" sequence="100"/>
</odoo>
