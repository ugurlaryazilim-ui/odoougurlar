<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_amazon_settings" model="ir.actions.act_window">
        <field name="name">Amazon Ayarları</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'amazon_integration'}</field>
    </record>

    <record id="res_config_settings_view_form_amazon" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.amazon</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Amazon" string="Amazon" name="amazon_integration" data-key="amazon_integration" logo="/amazon_integration/static/description/icon.png" icon="/amazon_integration/static/description/icon.png">
                    <block title="Mağaza Ayarları" name="amazon_store_block">
                        <setting string="Amazon Mağazaları" help="Amazon SP-API ayarlarını yapılandırmak için tıklayın">
                            <div class="row mt16">
                                <button type="action" name="%(amazon_integration.action_amazon_store)d" string="Mağazaları Yönet" class="btn-link"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    
</odoo>
