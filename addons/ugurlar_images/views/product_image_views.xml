<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Ürün formuna Alternatif Görseller sekmesi ekle -->
    <record id="product_template_form_extra_images" model="ir.ui.view">
        <field name="name">product.template.form.extra.images</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Alternatif Görseller" name="extra_images">
                    <field name="product_template_image_ids" nolabel="1">
                        <kanban>
                            <field name="id"/>
                            <field name="name"/>
                            <field name="sequence" widget="handle"/>
                            <field name="image_1920"/>
                            <templates>
                                <t t-name="card">
                                    <field name="image_1920" widget="image" options="{'size': [200, 200]}"/>
                                    <field name="name"/>
                                </t>
                            </templates>
                        </kanban>
                        <form string="Görsel Detay">
                            <group>
                                <field name="name"/>
                                <field name="sequence"/>
                                <field name="image_1920" widget="image"/>
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
