<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Ürün Şablonu (product.template) — Ana form view
         ============================================================ -->
    <record id="product_template_form_extra_images" model="ir.ui.view">
        <field name="name">product.template.form.extra.images</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Alternatif Görseller" name="extra_images">
                    <field name="product_template_image_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="image_1920" widget="image" options="{'size': [100, 100]}"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         Ürün Şablonu (product.template) — Genel form view
         ============================================================ -->
    <record id="product_template_form_view_extra_images" model="ir.ui.view">
        <field name="name">product.template.form.view.extra.images</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Alternatif Görseller" name="extra_images">
                    <field name="product_template_image_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="image_1920" widget="image" options="{'size': [100, 100]}"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         Ürün Varyantı (product.product) — Normal form view
         ============================================================ -->
    <record id="product_product_form_extra_images" model="ir.ui.view">
        <field name="name">product.product.form.extra.images</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Alternatif Görseller" name="extra_images">
                    <field name="product_template_image_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="image_1920" widget="image" options="{'size': [100, 100]}"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
