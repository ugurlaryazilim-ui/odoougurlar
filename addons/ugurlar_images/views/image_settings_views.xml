<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Resim modülü ayarlarını Ayarlar sayfasına ekle -->
    <record id="res_config_settings_view_form_image" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ugurlar_images</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Resimler" string="Resimler" name="ugurlar_images" groups="base.group_system">

                    <!-- Görsel Tarama Ayarları -->
                    <block title="Görsel Tarama Ayarları" name="image_scan_settings">
                        <setting string="Görsel Ayracı"
                                 help="Barkod ile sıra numarasını ayıran karakter">
                            <div class="content-group">
                                <field name="image_separator"/>
                            </div>
                        </setting>
                        <setting string="Ana Resim Sırası"
                                 help="Hangi sıradaki görsel vitrin görseli olsun?">
                            <div class="content-group">
                                <field name="main_image_index"/>
                            </div>
                        </setting>
                        <setting string="Eşleştirme Alanı"
                                 help="Dosya adındaki kod hangi ürün alanıyla eşleştirilsin?">
                            <div class="content-group">
                                <field name="image_match_field"/>
                            </div>
                        </setting>
                        <setting string="Üzerine Yaz"
                                 help="Ürünün mevcut görseli varsa yeni gelen ile değiştirilsin mi?">
                            <field name="image_overwrite"/>
                        </setting>
                    </block>

                    <!-- Sync Agent Ayarları -->
                    <block title="Sync Agent Ayarları (Windows Arka Plan)" name="sync_agent_settings">
                        <setting string="Sync Agent"
                                 help="Windows Sync Agent bağlantısını aktifleştirin.">
                            <field name="sync_agent_enabled"/>
                            <div class="content-group mt-2" invisible="not sync_agent_enabled">
                                <div class="row mt8">
                                    <label for="image_watch_folder" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="image_watch_folder" class="col-6" placeholder="Y:\Pazaryerleri\entegre ürün görselleri"/>
                                </div>
                                <div class="row mt8">
                                    <label for="sync_agent_api_key" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="sync_agent_api_key" class="col-6"/>
                                </div>
                                <div class="mt8">
                                    <button name="action_generate_api_key"
                                            type="object"
                                            string="Yeni API Anahtarı Oluştur"
                                            class="btn-primary"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- Tanılama ve Veri Düzeltme -->
                    <block title="Tanılama ve Veri Düzeltme" name="diagnostics_settings">
                        <setting string="Mevcut Görselleri Düzelt"
                                 help="Daha önce yüklenmiş olan ve e-ticarette gri kutu olarak görünen ek görsellerin Şablon ID (product_tmpl_id) bilgilerini onarır.">
                            <div class="mt-2">
                                <button name="action_fix_existing_images"
                                        type="object"
                                        string="Görsel Şablon Bağlantılarını Düzelt"
                                        class="btn-primary"
                                        invisible="fix_images_status == 'running'"/>
                                <button name="action_reset_fix_status"
                                        type="object"
                                        string="Düzeltmeyi Sıfırla"
                                        class="btn-secondary"
                                        invisible="fix_images_status != 'running'"/>
                            </div>
                            <div class="content-group mt-2">
                                <div class="row">
                                    <label for="fix_images_status" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="fix_images_status" readonly="1" class="col-6"/>
                                </div>
                                <div class="row mt8" invisible="fix_images_status == 'idle'">
                                    <label for="fix_images_progress" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="fix_images_progress" readonly="1" class="col-6"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
